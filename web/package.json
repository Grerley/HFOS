{
  "name": "hfos-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:worker": "opennextjs-cloudflare build",
    "deploy": "opennextjs-cloudflare build && wrangler deploy",
    "preview": "opennextjs-cloudflare build && wrangler dev",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply hfos-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply hfos-db --remote",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "drizzle-orm": "^0.36.4",
    "jose": "^5.9.6",
    "next": "^15",
    "react": "^19",
    "react-dom": "^19",
    "xlsx": "0.18.5"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5",
    "@opennextjs/cloudflare": "^1",
    "@types/node": "20.14.10",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "10.4.20",
    "drizzle-kit": "^0.28.1",
    "postcss": "8.4.47",
    "tailwindcss": "3.4.14",
    "typescript": "5.6.3",
    "vitest": "2.1.8",
    "wrangler": "^4"
  }
}
