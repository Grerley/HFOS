# ── HFOS environment template ─────────────────────────────────────────────
# Copy to `.env` (git-ignored) and fill in. Never commit real secrets.

# ── Backend ────────────────────────────────────────────────────────────────
# Database. Default is zero-config SQLite so the app runs from a clean repo.
# For PostgreSQL (production / docker-compose) use e.g.:
#   DATABASE_URL=postgresql+psycopg://hfos:hfos@localhost:5432/hfos
DATABASE_URL=sqlite:///./hfos.db

# JWT signing secret — MUST be overridden in any real deployment.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
HFOS_SECRET_KEY=dev-only-change-me-please-generate-a-real-secret

# Symmetric key for encrypting sensitive fields at rest (Fernet, urlsafe base64, 32 bytes).
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
HFOS_ENCRYPTION_KEY=

# Access-token lifetime (minutes)
HFOS_ACCESS_TOKEN_MINUTES=720

# CORS origins allowed to call the API (comma-separated)
HFOS_CORS_ORIGINS=http://localhost:3000

# Auto-create tables on startup (fine for SQLite/dev; use Alembic in prod)
HFOS_AUTO_CREATE_TABLES=true

# Copilot provider: "rules" (default, deterministic) or "llm" (extension point)
HFOS_COPILOT_PROVIDER=rules

# ── Frontend ─────────────────────────────────────────────────────────────
# Base URL of the backend API (used by the Next.js app)
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
